datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "workerd"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../../../shared/src/schemas"
  config   = "schema/zod-generator.config.json"
}

generator json {
  provider = "prisma-json-types-generator"
}
