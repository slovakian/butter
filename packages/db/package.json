{
	"name": "@butter/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"db:push": "dotenv -e ../../apps/server/.env -- zen db push --schema ./zenstack/schema/base.zmodel",
		"db:generate": "dotenv -e ../../apps/server/.env -- zen generate --schema ./zenstack/schema/base.zmodel --output ./zenstack/generated",
		"db:migrate": "dotenv -e ../../apps/server/.env -- zen migrate dev --schema ./zenstack/schema/base.zmodel",
		"db:seed": "dotenv -e ../../apps/server/.env -- bun ./zenstack/seed/index.ts",
		"db:reset": "dotenv -e ../../apps/server/.env -- zen migrate reset --schema ./zenstack/schema/base.zmodel"
	},
	"dependencies": {
		"@butter/env": "workspace:*",
		"@neondatabase/serverless": "^1.0.2",
		"@zenstackhq/orm": "^3.3.3",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@butter/config": "workspace:*",
		"@zenstackhq/cli": "^3.3.3",
		"dotenv-cli": "catalog:",
		"typescript": "catalog:"
	}
}
